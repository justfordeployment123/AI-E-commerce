# ─── Database (used by API and Prisma) ────────────────────────────────────────
DATABASE_URL=postgresql://ai_ecommerce:ai_ecommerce@localhost:5432/ai_ecommerce?schema=public

# ─── Redis (used by API) ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Frontend URL exposed to web & admin apps ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3002

# ─── Storage / MinIO (used by API) ────────────────────────────────────────────
GARAGE_ENDPOINT=http://localhost:9000
GARAGE_PUBLIC_URL=http://localhost:9000
GARAGE_ACCESS_KEY=minioadmin
GARAGE_SECRET_KEY=minioadmin
GARAGE_BUCKET=ai-ecommerce
