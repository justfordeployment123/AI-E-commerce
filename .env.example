# Root .env.example — shared reference for all apps in the monorepo.
# Copy relevant sections into each app's own .env file.

# ─── Database (API + Scraper) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://ai_ecommerce:ai_ecommerce@localhost:5432/ai_ecommerce?schema=public
# Production: DATABASE_URL=postgres://user:pass@host:5432/postgres?schema=public

# ─── Redis (API) ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: REDIS_URL=redis://default:pass@host:6379/0

# ─── API public URL (web + admin frontends) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3002
# Production: NEXT_PUBLIC_API_URL=https://api.techstopuk.com

# ─── Scraper service (internal — used by API cron trigger) ────────────────────
SCRAPER_URL=http://localhost:3003
# Production: SCRAPER_URL=http://scraper:3003  (Docker internal network hostname)

# ─── Storage / MinIO S3-compatible (API) ─────────────────────────────────────
GARAGE_ENDPOINT=http://localhost:9000
GARAGE_PUBLIC_URL=http://localhost:9000
GARAGE_ACCESS_KEY=minioadmin
GARAGE_SECRET_KEY=minioadmin
GARAGE_BUCKET=ai-ecommerce

# ─── Shippo (multi-carrier shipping labels) ───────────────────────────────────
SHIPPO_API_KEY=shippo_test_your_token_here
SHIPPO_SERVICE_LEVEL=royalmail_tracked48

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
