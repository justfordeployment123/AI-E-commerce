# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/e2e/playwright-report
/e2e/test-results
/e2e/.auth

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example
!.env.live.example
!**/.env.live.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Turborepo
.turbo

# Monorepo build outputs
apps/*/.next
apps/*/dist
apps/*/.next/cache

# Nested node_modules (hoisted to root by npm workspaces)
apps/*/node_modules
packages/*/node_modules
.claude/settings.local.json

# Local-only credentials reference — never commit real secrets/passwords
docs/TESTING_CREDENTIALS.md
