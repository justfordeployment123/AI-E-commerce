# URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:3002

# In production, point this to your deployed API:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Set to "true" to show competitor price scraping UI (buttons, pages, catalog price columns)
# Set to "false" (or omit) to hide all scraper-related UI
NEXT_PUBLIC_SCRAPER_ENABLED=true
