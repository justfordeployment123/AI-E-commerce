NODE_ENV=development
PORT=3002

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ai_ecommerce:ai_ecommerce@localhost:5432/ai_ecommerce?schema=public
# Production: postgres://user:pass@host:5432/postgres?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: redis://default:pass@host:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-32-plus-random-bytes
JWT_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback
# Production: GOOGLE_CALLBACK_URL=https://api.techstopuk.com/auth/google/callback

# ─── Scraper Service ──────────────────────────────────────────────────────────
# Internal URL of the scraper app — never publicly exposed
# The API fires a hourly cron job to this URL (fire and forget)
SCRAPER_URL=http://localhost:3003
# Production: SCRAPER_URL=http://scraper:3003  (Docker internal network hostname)

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://techstopuk.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_REDIRECT_URLS=http://localhost:3000,http://localhost:3001
# Production: ALLOWED_REDIRECT_URLS=https://techstopuk.com,https://www.techstopuk.com,https://admin.techstopuk.com

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ─── Storage (Garage / MinIO S3-compatible) ───────────────────────────────────
GARAGE_ENDPOINT=http://localhost:9000
GARAGE_PUBLIC_URL=http://localhost:9000
GARAGE_BUCKET=ai-ecommerce
GARAGE_ACCESS_KEY=your_access_key
GARAGE_SECRET_KEY=your_secret_key
# Optional: proxy images through the API instead of generating presigned S3 URLs.
# Use this when the storage endpoint is not publicly accessible over HTTPS.
# Production: GARAGE_PROXY_URL=https://api.techstopuk.com/storage
GARAGE_PROXY_URL=

# ─── Shippo (multi-carrier shipping labels) ───────────────────────────────────
# Sign up free at goshippo.com — grab your API token from Settings → API
# Use shippo_test_* in dev, shippo_live_* in production
SHIPPO_API_KEY=shippo_test_your_token_here
SHIPPO_SERVICE_LEVEL=royalmail_tracked48

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ─── Stripe (payments) ────────────────────────────────────────────────────────
# Use sk_test_* in development, sk_live_* in production
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Webhook secret: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
