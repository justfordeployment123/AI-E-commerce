NODE_ENV=development
PORT=3002
DATABASE_URL=postgresql://user:password@localhost:5432/smatway?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-32-plus-random-bytes
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
ALLOWED_REDIRECT_URLS=http://localhost:3000,http://localhost:3001

RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=noreply@yourdomain.com
# true = actually send OTP emails via Resend. false = skip send, log OTP to console (use while a Resend domain is not yet verified).
OTP_SEND_EMAIL=false

WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

GARAGE_ENDPOINT=http://localhost:9000
GARAGE_PUBLIC_URL=http://localhost:9000
GARAGE_BUCKET=smatway
GARAGE_ACCESS_KEY=your_garage_access_key
GARAGE_SECRET_KEY=your_garage_secret_key

# ─── Paystack (payments + payouts) ──────────────────────────────────────────
# Secret key from your Paystack dashboard. Use sk_test_… for development,
# sk_live_… for production. Required for /payments/* and /payouts/* to work.
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
# Where Paystack redirects users after they finish hosted checkout. Must be
# reachable on the public web in production.
PAYSTACK_CALLBACK_URL=http://localhost:3000/dashboard/pay/callback
# Platform's cut on every completed trip. 0.1 = 10%. Captured onto the
# Payout row at creation time so historical payouts don't change if you
# adjust the rate later.
PLATFORM_COMMISSION_RATE=0.1
# true = call Paystack /transfer immediately when a trip completes.
# Requires Transfers OTP to be DISABLED in your Paystack dashboard
# (Settings → Preferences). false = payout sits PENDING for an admin to
# release manually from /admin/dashboard/payouts.
PAYSTACK_AUTO_PAYOUT=false
# DEV ONLY. true = skip Paystack's resolve-account + transfer-recipient
# calls when a transporter saves their bank details. Synthesises a fake
# recipient code so the UI flow can be tested even if Paystack's test
# resolver rejects the fake account numbers. NEVER enable in production —
# it lets transporters point payouts at any unverified bank account.
# Same flag also bypasses Flutterwave bank verification + simulates Flutterwave
# transfers, since both providers use the same dev-mode workaround.
PAYSTACK_DEV_BYPASS_BANK_VERIFICATION=false

# ─── Flutterwave (alternative payment + payout provider) ────────────────────
# Secret key from Flutterwave dashboard → Settings → API. sk_test_… for dev.
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx-X
# Random string YOU set under Settings → Webhooks → Secret hash. Flutterwave
# echoes it back in the verif-hash header on every webhook so we can confirm
# the call really came from them. Keep it secret and rotate if leaked.
FLW_SECRET_HASH=set-this-to-a-random-string
# Where Flutterwave sends users after hosted-checkout completes. Same shape
# as PAYSTACK_CALLBACK_URL — must be reachable on the public web in prod.
FLW_REDIRECT_URL=http://localhost:3000/dashboard/pay/callback
