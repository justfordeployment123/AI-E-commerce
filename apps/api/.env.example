NODE_ENV=development
PORT=3002

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ai_ecommerce?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-32-plus-random-bytes
JWT_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_REDIRECT_URLS=http://localhost:3000

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key

# ─── Storage (Garage / MinIO S3-compatible) ───────────────────────────────────
GARAGE_ENDPOINT=http://localhost:9000
GARAGE_PUBLIC_URL=http://localhost:9000
GARAGE_BUCKET=ai-ecommerce
GARAGE_ACCESS_KEY=your_access_key
GARAGE_SECRET_KEY=your_secret_key

# ─── Shippo (Multi-carrier Shipping Labels) ───────────────────────────────────
# Sign up free at goshippo.com — grab your API token from Settings → API
# Use shippo_test_* key in dev — real test labels generated instantly, no carrier account needed
# In production swap for shippo_live_* and connect a carrier in the Shippo dashboard
# Leave blank in development — a mock label will be generated instead
SHIPPO_API_KEY=shippo_test_your_token_here
SHIPPO_SERVICE_LEVEL=royalmail_tracked48

# ─── Email / SMTP (for shipping label delivery) ───────────────────────────────
# Gmail: enable 2FA, then generate an App Password at myaccount.google.com/apppasswords
# For other providers adjust SMTP_HOST and SMTP_PORT accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
