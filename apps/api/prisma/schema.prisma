generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TradeInStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COUNTER_OFFERED
  COMPLETED
  CANCELLED
}

enum RepairStatus {
  SUBMITTED
  QUOTE_SENT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ScraperRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum Condition {
  NEW
  A
  B
  C
  F
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String
  phone        String?
  address      String?
  city         String?
  postcode     String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders        Order[]
  tradeIns      TradeIn[]
  repairs       Repair[]
  notifications Notification[]
  reviews       Review[]

  @@index([createdAt])
  @@map("users")
}

model Product {
  id                 String            @id @default(uuid())

  catalogId          String?
  catalog            DeviceCatalog?    @relation(fields: [catalogId], references: [id])

  otherBrandId       String?
  otherBrand         OtherBrand?       @relation(fields: [otherBrandId], references: [id])

  otherSubcategoryId String?
  otherSubcategory   OtherSubcategory? @relation(fields: [otherSubcategoryId], references: [id])

  name         String
  slug         String    @unique
  condition    Condition
  storage      String    @default("")
  price        Float?
  comparePrice Float?
  stock        Int       @default(0)
  images       String[]
  specs        Json      @default("{}")
  description  String?
  rating       Float     @default(0)
  reviewCount  Int       @default(0)
  isActive     Boolean   @default(true)
  pricingStatus String   @default("no_data")
  // "auto_priced" | "manual" | "flagged" | "no_data"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orderItems OrderItem[]
  reviews    Review[]

  @@index([catalogId])
  @@index([otherBrandId])
  @@index([otherSubcategoryId])
  @@index([condition])
  @@index([isActive, createdAt])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  subtotal        Float
  shipping        Float       @default(0)
  total           Float
  shippingAddress Json
  paymentMethod   String?
  paymentIntentId String?
  refundId        String?
  refundAmount    Float?
  discount        Float   @default(0)
  trackingNumber  String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@map("order_items")
}

model TradeIn {
  id              String        @id @default(uuid())
  reference       String        @unique @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  category        String
  brand           String
  model           String
  specs           Json          @default("{}")
  condition       Condition
  answers         Json          @default("{}")
  fulfillment     String        // ship | dropoff
  offerPrice      Float
  images          String[]
  status          TradeInStatus @default(SUBMITTED)
  contact         Json
  storeId         String?
  customerNotes   String?   // extra notes from customer at submission
  adminNotes      String?
  counterOffer    Float?
  trackingNumber  String?
  labelUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("trade_ins")
}

model Repair {
  id             String       @id @default(uuid())
  reference      String       @unique @default(cuid())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  deviceType     String
  brand          String
  model          String
  issue          String
  issueNotes     String?
  fulfillment    String       // ship | dropoff
  images         String[]
  status         RepairStatus @default(SUBMITTED)
  quote          Float?
  contact        Json
  adminNotes     String?
  trackingNumber String?
  labelUrl       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("repairs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model PricingConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Float
  label     String?
  updatedAt DateTime @updatedAt

  @@map("pricing_configs")
}

model Store {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  postcode     String
  phone        String?
  openingHours String?
  mapsEmbedUrl String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("stores")
}

model Category {
  id              String          @id @default(uuid())
  name            String          @unique
  slug            String          @unique
  description     String?
  image           String?
  images          String[]        @default([])
  isActive        Boolean         @default(true)
  isSellable      Boolean         @default(false)
  isRepairable    Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  brandCategories BrandCategory[]

  @@map("categories")
}

model Brand {
  id              String          @id @default(uuid())
  name            String          @unique
  slug            String          @unique
  logo            String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  brandCategories BrandCategory[]

  @@map("brands")
}

model BrandCategory {
  id             String        @id @default(uuid())
  brandId        String
  brand          Brand         @relation(fields: [brandId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  alias          String?       // display name within this category e.g. "iPhone", "Xbox" — null = fall back to brand.name
  images         String[]
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deviceCatalogs DeviceCatalog[]

  @@unique([brandId, categoryId])
  @@map("brand_categories")
}

model DeviceCatalog {
  id              String        @id @default(uuid())
  brandCategoryId String
  brandCategory   BrandCategory @relation(fields: [brandCategoryId], references: [id])
  model           String
  storageOptions  String[]
  isActive           Boolean       @default(true)
  tradeInEnabled     Boolean       @default(true)
  manualMarketPrice  Float?
  createdAt          DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  products        Product[]

  @@unique([brandCategoryId, model])
  @@index([brandCategoryId])
  @@map("device_catalog")
}

model ScrapedPrice {
  id                 String   @id @default(uuid())
  deviceKey          String   @unique  // "Apple iPhone 15 Plus 128GB"
  brand              String
  model              String
  storage            String
  cexSellPrice       Float?
  cexCashPrice       Float?
  cexExchangePrice   Float?
  backMarketPrice    Float?
  musicMagpiePrice   Float?
  envirofonePrice    Float?
  marketPrice        Float?   // best available price computed from all sources
  scrapedAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([brand, model])
  @@map("scraped_prices")
}

model ScraperRun {
  id            String    @id @default(uuid())
  status        ScraperRunStatus @default(RUNNING)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  totalScraped  Int?
  errorMessage  String?

  @@map("scraper_runs")
}

model HelplineNumber {
  id        String   @id @default(uuid())
  label     String   // e.g. "Sales", "Support", "General"
  number    String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("helpline_numbers")
}

model SupportChat {
  id          String        @id @default(uuid())
  guestName   String
  guestEmail  String?
  orderRef    String?
  status      String        @default("open")  // open | closed
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages ChatMessage[]

  @@index([status])
  @@index([createdAt])
  @@map("support_chats")
}

model ChatMessage {
  id        String      @id @default(uuid())
  chatId    String
  chat      SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    String      // "customer" | "admin"
  body      String
  createdAt DateTime    @default(now())

  @@index([chatId])
  @@map("chat_messages")
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName  String?
  rating     Int      // 1–5
  body       String
  images     String[]
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId, isApproved])
  @@index([createdAt])
  @@map("reviews")
}

model PromoSlide {
  id          String   @id @default(uuid())
  imgKey      String?
  tabTitle    String   @default("")
  tag         String   @default("")
  titleLine1  String   @default("")
  titleLine2  String   @default("")
  titleItalic String   @default("")
  title       String   @default("")
  subtitle    String   @default("")
  badgeA      String   @default("")
  badgeB      String   @default("")
  specs       String   @default("")
  themeColor  String   @default("from-blue-500 to-indigo-600 dark:from-blue-400 dark:to-indigo-400")
  bgGlow      String   @default("rgba(59,130,246,0.15)")
  btnText     String   @default("Shop Now")
  btnLink     String   @default("/")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  layoutTheme String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("promo_slides")
}

model Banner {
  id        String   @id @default(uuid())
  key       String   @unique  // S3 key: "banners/gaming.jpg"
  label     String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model OtherBrand {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("other_brands")
}

model OtherSubcategory {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("other_subcategories")
}

model AppSetting {
  key            String   @id
  encryptedValue String
  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

// Devices shown in the search autocomplete (DeviceSearchBox) — admin-managed
model TradeInDevice {
  id        String   @id @default(cuid())
  name      String   // model name, e.g. "iPhone 15 Pro"
  brand     String   // brand name, e.g. "Apple"
  category  String   // wizard category ID: Phone | Tablet | Console | Laptop | Audio | Smartwatch | Other
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brand, name])
  @@map("trade_in_devices")
}
