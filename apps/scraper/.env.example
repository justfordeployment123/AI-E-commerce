NODE_ENV=development
PORT=3003

# ─── Database ─────────────────────────────────────────────────────────────────
# Must point to the same Postgres instance as the API (shares the same schema)
DATABASE_URL=postgresql://ai_ecommerce:ai_ecommerce@localhost:5432/ai_ecommerce?schema=public
# Production: postgres://user:pass@host:5432/postgres?schema=public

# ─── Jina.ai Reader ───────────────────────────────────────────────────────────
# Free API key from https://jina.ai — removes rate limit (1M tokens/month free)
# Without this key the scraper still works but is limited to ~20 req/min
JINA_API_KEY=your_jina_api_key_here

# ─── Proxy rotation (optional) ─────────────────────────────────────────────────
# Comma-separated list of proxies for the Playwright-driven CeX scraping.
# Format per entry: http://[user:pass@]host:port
# Leave unset to run from a single fixed IP (current default, no behavior change).
# SCRAPER_PROXIES=http://user1:pass1@proxy1.example.com:8000,http://user2:pass2@proxy2.example.com:8000

# How many devices to scrape through one proxy before rotating to the next.
# Only takes effect when SCRAPER_PROXIES is set. Default: 25
# SCRAPER_PROXY_ROTATE_EVERY=25
