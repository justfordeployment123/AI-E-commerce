# ─── API ──────────────────────────────────────────────────────────────────────
# URL of the backend API.
# In development this defaults to http://localhost:3002 if left unset.
# In production this MUST be set at Docker build time (--build-arg) because
# Next.js bakes NEXT_PUBLIC_* variables into the client bundle during `npm run build`.
NEXT_PUBLIC_API_URL=http://localhost:3002
# Production: NEXT_PUBLIC_API_URL=https://api.techstopuk.com

# ─── Stripe (payments) ────────────────────────────────────────────────────────
# Publishable key from Stripe Dashboard → Developers → API Keys
# Use pk_test_* in development, pk_live_* in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
